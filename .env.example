# ============= GEMINI AI CONFIGURATION =============
# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your key from: https://ai.google.dev/
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Specify which Gemini model to use
# Available models: gemini-2.0-flash, gemini-1.5-flash, etc.
# Default: gemini-2.0-flash
GEMINI_MODEL="gemini-2.0-flash"

# ============= SERVER CONFIGURATION =============
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# NODE_ENV: Deployment environment (development | production)
NODE_ENV="development"

# ============= OPTIONAL: SUPABASE CONFIGURATION =============
# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Your Supabase anonymous key
SUPABASE_ANON_KEY=""

# ============= OPTIONAL: FIREBASE CONFIGURATION =============
# FIREBASE_API_KEY: Your Firebase API key
FIREBASE_API_KEY=""

# ============= LOGGING =============
# LOG_LEVEL: Set logging verbosity (debug | info | warn | error)
LOG_LEVEL="info"

# ============= RATE LIMITING =============
# RATE_LIMIT_WINDOW_MS: Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS="900000"

# RATE_LIMIT_MAX_REQUESTS: Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS="100"
